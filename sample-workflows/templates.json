  {
    "id": "template-document-summarizer",
    "name": "Document Summarizer",
    "description": "Read a document, extract its content, generate a summary, and format it as clean markdown.",
    "category": "Productivity",
    "node_count": 5,
    "workflow_json": {
      "nodes": [
        {
          "id": "node_1",
          "type": "input",
          "position": { "x": 50, "y": 200 },
          "data": {
            "label": "Input",
            "title": "Document Path",
            "nodeType": "input",
            "status": "idle",
            "config": { "inputType": "text", "defaultValue": "" },
            "configPreview": "text"
          }
        },
        {
          "id": "node_2",
          "type": "file",
          "position": { "x": 320, "y": 200 },
          "data": {
            "label": "File",
            "title": "Read Document",
            "nodeType": "file",
            "status": "idle",
            "config": { "operation": "read", "fileType": "txt", "filename": "{{Document Path.output}}" },
            "configPreview": "read txt"
          }
        },
        {
          "id": "node_3",
          "type": "llm",
          "position": { "x": 590, "y": 200 },
          "data": {
            "label": "LLM Call",
            "title": "Summarize",
            "nodeType": "llm",
            "status": "idle",
            "config": {
              "provider": "claude",
              "model": "claude-sonnet-4-20250514",
              "systemPrompt": "You are an expert summarizer. Create concise, comprehensive summaries that capture the key points and main arguments of a document.",
              "userPrompt": "Summarize the following document:\n\n{{Read Document.output}}",
              "temperature": 0.5,
              "maxTokens": 1500
            },
            "configPreview": "claude sonnet"
          }
        },
        {
          "id": "node_4",
          "type": "transform",
          "position": { "x": 860, "y": 200 },
          "data": {
            "label": "Transform",
            "title": "Format Markdown",
            "nodeType": "transform",
            "status": "idle",
            "config": { "operation": "template", "template": "# Document Summary\n\n{{Summarize.output}}\n\n---\n*Generated by FlowPilot*" },
            "configPreview": "template"
          }
        },
        {
          "id": "node_5",
          "type": "output",
          "position": { "x": 1130, "y": 200 },
          "data": {
            "label": "Output",
            "title": "Summary Output",
            "nodeType": "output",
            "status": "idle",
            "config": { "outputType": "display", "label": "Summary" },
            "configPreview": "display"
          }
        }
      ],
      "edges": [
        { "id": "e1-2", "source": "node_1", "target": "node_2", "animated": true, "type": "smoothstep", "style": { "stroke": "#555", "strokeDasharray": "5 5" } },
        { "id": "e2-3", "source": "node_2", "target": "node_3", "animated": true, "type": "smoothstep", "style": { "stroke": "#555", "strokeDasharray": "5 5" } },
        { "id": "e3-4", "source": "node_3", "target": "node_4", "animated": true, "type": "smoothstep", "style": { "stroke": "#555", "strokeDasharray": "5 5" } },
        { "id": "e4-5", "source": "node_4", "target": "node_5", "animated": true, "type": "smoothstep", "style": { "stroke": "#555", "strokeDasharray": "5 5" } }
      ]
    }
