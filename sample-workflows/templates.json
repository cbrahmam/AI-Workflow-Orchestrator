  {
    "id": "template-content-classifier",
    "name": "Conditional Content Classifier",
    "description": "Classify text sentiment with AI, then branch to generate different responses based on positive or negative sentiment.",
    "category": "AI",
    "node_count": 6,
    "workflow_json": {
      "nodes": [
        {
          "id": "node_1",
          "type": "input",
          "position": { "x": 50, "y": 250 },
          "data": {
            "label": "Input",
            "title": "Customer Message",
            "nodeType": "input",
            "status": "idle",
            "config": { "inputType": "text", "defaultValue": "" },
            "configPreview": "text"
          }
        },
        {
          "id": "node_2",
          "type": "llm",
          "position": { "x": 320, "y": 250 },
          "data": {
            "label": "LLM Call",
            "title": "Classify Sentiment",
            "nodeType": "llm",
            "status": "idle",
            "config": {
              "provider": "claude",
              "model": "claude-sonnet-4-20250514",
              "systemPrompt": "Classify the sentiment of the message. Respond with ONLY one word: 'positive' or 'negative'.",
              "userPrompt": "Classify the sentiment:\n\n{{Customer Message.output}}",
              "temperature": 0.1,
              "maxTokens": 10
            },
            "configPreview": "claude sonnet"
          }
        },
        {
          "id": "node_3",
          "type": "condition",
          "position": { "x": 590, "y": 250 },
          "data": {
            "label": "Condition",
            "title": "Is Positive?",
            "nodeType": "condition",
            "status": "idle",
            "config": { "conditionType": "contains", "compareValue": "positive", "trueLabel": "Positive", "falseLabel": "Negative" },
            "configPreview": "contains"
          }
        },
        {
          "id": "node_4",
          "type": "llm",
          "position": { "x": 880, "y": 120 },
          "data": {
            "label": "LLM Call",
            "title": "Positive Response",
            "nodeType": "llm",
            "status": "idle",
            "config": {
              "provider": "claude",
              "model": "claude-sonnet-4-20250514",
              "systemPrompt": "Generate a warm, appreciative response to a positive customer message. Be concise and professional.",
              "userPrompt": "Generate a positive response to this customer:\n\n{{Customer Message.output}}",
              "temperature": 0.7,
              "maxTokens": 512
            },
            "configPreview": "claude sonnet"
          }
        },
        {
          "id": "node_5",
          "type": "llm",
          "position": { "x": 880, "y": 380 },
          "data": {
            "label": "LLM Call",
            "title": "Escalation Response",
            "nodeType": "llm",
            "status": "idle",
            "config": {
              "provider": "claude",
              "model": "claude-sonnet-4-20250514",
              "systemPrompt": "Generate an empathetic escalation response to a negative customer message. Acknowledge their concern and offer to connect them with a specialist.",
              "userPrompt": "Generate an escalation response for this negative message:\n\n{{Customer Message.output}}",
              "temperature": 0.7,
              "maxTokens": 512
            },
            "configPreview": "claude sonnet"
          }
        },
        {
          "id": "node_6",
          "type": "output",
          "position": { "x": 1160, "y": 250 },
          "data": {
            "label": "Output",
            "title": "Response",
            "nodeType": "output",
            "status": "idle",
            "config": { "outputType": "display", "label": "Response" },
            "configPreview": "display"
          }
        }
      ],
      "edges": [
        { "id": "e1-2", "source": "node_1", "target": "node_2", "animated": true, "type": "smoothstep", "style": { "stroke": "#555", "strokeDasharray": "5 5" } },
        { "id": "e2-3", "source": "node_2", "target": "node_3", "animated": true, "type": "smoothstep", "style": { "stroke": "#555", "strokeDasharray": "5 5" } },
        { "id": "e3-4", "source": "node_3", "sourceHandle": "true", "target": "node_4", "animated": true, "type": "smoothstep", "style": { "stroke": "#555", "strokeDasharray": "5 5" } },
        { "id": "e3-5", "source": "node_3", "sourceHandle": "false", "target": "node_5", "animated": true, "type": "smoothstep", "style": { "stroke": "#555", "strokeDasharray": "5 5" } },
        { "id": "e4-6", "source": "node_4", "target": "node_6", "animated": true, "type": "smoothstep", "style": { "stroke": "#555", "strokeDasharray": "5 5" } },
        { "id": "e5-6", "source": "node_5", "target": "node_6", "animated": true, "type": "smoothstep", "style": { "stroke": "#555", "strokeDasharray": "5 5" } }
      ]
    }
