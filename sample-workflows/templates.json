[
  {
    "id": "template-content-research",
    "name": "Content Research & Writing",
    "description": "Research a topic by scraping the web, summarize findings, and generate a polished article.",
    "category": "Content",
    "node_count": 5,
    "workflow_json": {
      "nodes": [
        {
          "id": "node_1",
          "type": "input",
          "position": { "x": 50, "y": 200 },
          "data": {
            "label": "Input",
            "title": "Topic Input",
            "nodeType": "input",
            "status": "idle",
            "config": { "inputType": "text", "defaultValue": "" },
            "configPreview": "text"
          }
        },
        {
          "id": "node_2",
          "type": "scrape",
          "position": { "x": 320, "y": 200 },
          "data": {
            "label": "Web Scrape",
            "title": "Research Sources",
            "nodeType": "scrape",
            "status": "idle",
            "config": { "url": "{{Topic Input.output}}", "extractionType": "fullText", "selector": "", "maxPages": 3 },
            "configPreview": "{{Topic Input.output}}"
          }
        },
        {
          "id": "node_3",
          "type": "llm",
          "position": { "x": 590, "y": 200 },
          "data": {
            "label": "LLM Call",
            "title": "Summarize Research",
            "nodeType": "llm",
            "status": "idle",
            "config": {
              "provider": "claude",
              "model": "claude-sonnet-4-20250514",
              "systemPrompt": "You are a research analyst. Summarize the key findings from the provided content into clear, structured bullet points.",
              "userPrompt": "Summarize the following research content:\n\n{{Research Sources.output}}",
              "temperature": 0.5,
              "maxTokens": 1024
            },
            "configPreview": "claude sonnet"
          }
        },
        {
          "id": "node_4",
          "type": "llm",
          "position": { "x": 860, "y": 200 },
          "data": {
            "label": "LLM Call",
            "title": "Write Article",
            "nodeType": "llm",
            "status": "idle",
            "config": {
              "provider": "claude",
              "model": "claude-sonnet-4-20250514",
              "systemPrompt": "You are a skilled content writer. Write engaging, well-structured articles based on research summaries.",
              "userPrompt": "Write a comprehensive article based on these research findings:\n\n{{Summarize Research.output}}",
              "temperature": 0.7,
              "maxTokens": 2048
            },
            "configPreview": "claude sonnet"
          }
        },
        {
          "id": "node_5",
          "type": "output",
          "position": { "x": 1130, "y": 200 },
          "data": {
            "label": "Output",
            "title": "Final Article",
            "nodeType": "output",
            "status": "idle",
            "config": { "outputType": "display", "label": "Article" },
            "configPreview": "display"
          }
        }
      ],
      "edges": [
        { "id": "e1-2", "source": "node_1", "target": "node_2", "animated": true, "type": "smoothstep", "style": { "stroke": "#555", "strokeDasharray": "5 5" } },
        { "id": "e2-3", "source": "node_2", "target": "node_3", "animated": true, "type": "smoothstep", "style": { "stroke": "#555", "strokeDasharray": "5 5" } },
        { "id": "e3-4", "source": "node_3", "target": "node_4", "animated": true, "type": "smoothstep", "style": { "stroke": "#555", "strokeDasharray": "5 5" } },
        { "id": "e4-5", "source": "node_4", "target": "node_5", "animated": true, "type": "smoothstep", "style": { "stroke": "#555", "strokeDasharray": "5 5" } }
      ]
    }
  },
  {
    "id": "template-lead-research",
    "name": "Lead Research Pipeline",
    "description": "Research a company by scraping their website, extract key information, and generate personalized outreach.",
    "category": "Sales",
    "node_count": 5,
    "workflow_json": {
      "nodes": [
        {
          "id": "node_1",
          "type": "input",
          "position": { "x": 50, "y": 200 },
          "data": {
            "label": "Input",
            "title": "Company URL",
            "nodeType": "input",
            "status": "idle",
            "config": { "inputType": "text", "defaultValue": "" },
            "configPreview": "text"
          }
        },
        {
          "id": "node_2",
          "type": "scrape",
          "position": { "x": 320, "y": 200 },
          "data": {
            "label": "Web Scrape",
            "title": "Scrape Website",
            "nodeType": "scrape",
            "status": "idle",
            "config": { "url": "{{Company URL.output}}", "extractionType": "fullText", "selector": "", "maxPages": 2 },
            "configPreview": "{{Company URL.output}}"
          }
        },
        {
          "id": "node_3",
          "type": "llm",
          "position": { "x": 590, "y": 200 },
          "data": {
            "label": "LLM Call",
            "title": "Extract Info",
            "nodeType": "llm",
            "status": "idle",
            "config": {
              "provider": "claude",
              "model": "claude-sonnet-4-20250514",
              "systemPrompt": "Extract key company information: industry, size, products/services, recent news, pain points. Return as structured JSON.",
              "userPrompt": "Extract company information from this website content:\n\n{{Scrape Website.output}}",
              "temperature": 0.3,
              "maxTokens": 1024
            },
            "configPreview": "claude sonnet"
          }
        },
        {
          "id": "node_4",
